#include <stdio.h>
#include <string.h>

int main() {
    char input[20], stack[20];
    int i = 0, top = -1;

    printf("Enter string: ");
    scanf("%s", input);

    printf("\nStack\tInput\tAction\n");

    while (i < strlen(input)) {
        stack[++top] = input[i];
        stack[top+1] = '\0';

        printf("%s\t%s\tShift\n", stack, input+i+1);
        i++;
    }

    printf("%s\t\tReduce\n", stack);
    printf("%s\t\tAccept\n", stack);
}
